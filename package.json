{
  "name": "classvault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "claude:doctor": "bash scripts/claude-doctor.sh",
    "claude:tokens": "bash scripts/claude-token-audit.sh",
    "claude:pack": "bash scripts/repomix-selected.sh",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
