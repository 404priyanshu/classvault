# ClassVault environment
# Copy this file to .env and fill in deployment-specific values.

# Core
# Postgres connection string. Use Neon in production, or local Postgres in dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/classvault"

# Public app origin used to build OAuth callback URLs and absolute links.
APP_ORIGIN="http://localhost:3000"

# Authentication
# Optional Google OAuth credentials. Configure the redirect URI in Google Cloud as:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Campus beta access. Comma-separated domains; leave empty to allow any
# verified Google/email OTP account in local development.
ALLOWED_EMAIL_DOMAINS="classvault.edu"

# Comma-separated emails promoted to ADMIN on sign-in/seed.
ADMIN_EMAILS="admin@classvault.edu"

# Email delivery
# Use EMAIL_PROVIDER="ses" for AWS SES, "resend" for Resend, or "console" for local dev.
# In local development, missing provider credentials log the OTP to the dev server console.
EMAIL_PROVIDER="ses"
EMAIL_FROM="ClassVault <no-reply@classvault.edu>"
EMAIL_REPLY_TO=""
EMAIL_OTP_SECRET="replace-with-a-long-random-string"

# Resend email delivery. Required only when EMAIL_PROVIDER="resend".
RESEND_API_KEY=""

# AWS SES email delivery. Required only when EMAIL_PROVIDER="ses".
AWS_SES_REGION="us-east-1"
AWS_DEFAULT_REGION=""

# Object storage
# AWS S3 direct-upload storage. Leave AWS_S3_BUCKET empty for local filesystem uploads.
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_S3_BUCKET=""

# Optional. Use a CloudFront/custom/public S3 base URL. If empty, downloads use short-lived signed S3 URLs.
AWS_S3_PUBLIC_BASE_URL=""

# Cloudflare R2 compatibility values
# Optional bookkeeping for R2 deployments. The current upload code reads the AWS_* names above.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# AI providers
# AI roadmap generation. Gemini is used first when configured; OpenAI is the fallback.
# Keep these keys server-side only. Do not prefix them with NEXT_PUBLIC_.
GEMINI_API_KEY=""
# Flash-Lite is fast + cheap and avoids the flagship's demand-spike 503s and
# per-model quota 429s. The app also auto-falls-back across flash-lite models.
AI_GEMINI_MODEL="gemini-3.1-flash-lite"
OPENAI_API_KEY=""
AI_OPENAI_MODEL="gpt-5.5"
AI_REQUEST_TIMEOUT_MS="20000"

# Billing / monetization stubs (B2B uni subscriptions + freemium per docs/roadmap.md financial focus).
# Stripe for checkout + webhooks; Institution.plan/quotas for enforcement. Add NEXT_PUBLIC_ only for publishable.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
