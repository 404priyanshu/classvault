// ClassVault release data model for Neon/Postgres.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  MODERATOR
  ADMIN
}

enum NoteStatus {
  PENDING
  PUBLISHED
  REJECTED
  HIDDEN
  DELETED
}

enum FileType {
  PDF
  DOCX
  PPTX
  ZIP
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(STUDENT)
  department   String?
  semester     String?
  age          Int?
  subjectPreferences String[] @default([])
  collegeName  String?
  collegeEmail String?  @unique
  collegeVerifiedAt DateTime?
  onboardingCompletedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes      Note[]
  savedNotes SavedNote[]
  ratings    Rating[]
  downloads  DownloadEvent[]
  studyTasks StudyTask[]
  notifications Notification[]
  comments   Comment[]
  sessions   Session[]
  oauthAccounts OAuthAccount[]
  collegeVerificationCodes CollegeVerificationCode[]
  moderationEvents ModerationEvent[]
  reports Report[] @relation("ReporterReports")
  resolvedReports Report[] @relation("ResolverReports")
}

// Server-side session store. The browser cookie holds the raw token; only its
// SHA-256 hash is persisted, so a leaked database row cannot be replayed.
model Session {
  tokenHash String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// External login identities linked to ClassVault users. Provider access and
// refresh tokens are intentionally not stored.
model OAuthAccount {
  provider          String
  providerAccountId String
  userId            String
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

// Short-lived email sign-up codes. Only a keyed HMAC of the six-digit code is
// stored so database rows cannot be replayed as login credentials.
model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  name       String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model CollegeVerificationCode {
  id          String    @id @default(cuid())
  userId      String
  collegeName String
  email       String
  codeHash    String
  attempts    Int       @default(0)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model Note {
  id            String   @id @default(cuid())
  title         String
  description   String
  subject       String
  semester      String
  courseCode    String
  unit          String
  topic         String
  fileType      FileType
  fileSizeBytes Int
  pageCount     Int?
  storageKey    String?
  status        NoteStatus @default(PUBLISHED)
  rejectionReason String?
  reviewedAt    DateTime?
  reviewedById  String?
  ratingAverage Float    @default(0)
  ratingCount   Int      @default(0)
  downloadCount Int      @default(0)
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  /// Generated column (see note_search_vector migration); kept as Unsupported
  /// so Prisma preserves it without trying to manage its value.
  searchVector  Unsupported("tsvector")?

  owner     User            @relation(fields: [ownerId], references: [id])
  tags      NoteTag[]
  savedBy   SavedNote[]
  ratings   Rating[]
  downloads DownloadEvent[]
  moderationEvents ModerationEvent[]
  reports   Report[]
  comments  Comment[]

  @@index([subject])
  @@index([semester])
  @@index([courseCode])
  @@index([status])
  @@index([ownerId])
}

model ModerationEvent {
  id          String   @id @default(cuid())
  noteId      String
  moderatorId String
  action      String
  reason      String?
  createdAt   DateTime @default(now())

  note      Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  moderator User @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([moderatorId])
}

model Report {
  id          String   @id @default(cuid())
  noteId      String
  reporterId  String?
  reason      String
  details     String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  resolverId  String?

  note     Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  reporter User? @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)
  resolver User? @relation("ResolverReports", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([noteId])
  @@index([reporterId])
  @@index([status])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  notes NoteTag[]
}

model NoteTag {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

model SavedNote {
  userId    String
  noteId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([userId])
}

model Rating {
  userId    String
  noteId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
}

// Record of a raw file upload, written by /api/uploads before any Note
// exists. POST /api/notes validates its storageKey against this table so the
// browser cannot claim arbitrary keys or lie about size/type.
model UploadedFile {
  storageKey   String   @id
  userId       String
  provider     String   @default("LOCAL")
  mimeType     String
  sizeBytes    Int
  originalName String
  publicUrl    String?
  uploadedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DownloadEvent {
  id        String   @id @default(cuid())
  userId    String?
  noteId    String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  note Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([noteId, createdAt])
}

// Personal study checklist shown on the dashboard. Per-user, no sharing.
model StudyTask {
  id        String   @id @default(cuid())
  userId    String
  title     String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// In-app notification (e.g. note approved/rejected). payload is type-specific
// JSON (noteId, noteTitle, reason, ...). readAt null = unread.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// Comments / Q&A on a note. One level of replies (parentId points only at a
// top-level comment). status: VISIBLE | HIDDEN (staff) | DELETED (author).
model Comment {
  id        String        @id @default(cuid())
  noteId    String
  authorId  String
  parentId  String?
  body      String
  status    CommentStatus @default(VISIBLE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  note    Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([noteId, createdAt])
  @@index([parentId])
}
