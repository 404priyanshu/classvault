// ClassVault release data model for Neon/Postgres.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  MODERATOR
  ADMIN
}

enum NoteStatus {
  PENDING
  PUBLISHED
  REJECTED
  HIDDEN
  DELETED
}

enum FileType {
  PDF
  DOCX
  PPTX
  ZIP
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(STUDENT)
  department   String?
  semester     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes      Note[]
  savedNotes SavedNote[]
  ratings    Rating[]
  downloads  DownloadEvent[]
  sessions   Session[]
  oauthAccounts OAuthAccount[]
  moderationEvents ModerationEvent[]
  reports Report[] @relation("ReporterReports")
  resolvedReports Report[] @relation("ResolverReports")
}

// Server-side session store. The browser cookie holds the raw token; only its
// SHA-256 hash is persisted, so a leaked database row cannot be replayed.
model Session {
  tokenHash String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// External login identities linked to ClassVault users. Provider access and
// refresh tokens are intentionally not stored.
model OAuthAccount {
  provider          String
  providerAccountId String
  userId            String
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Note {
  id            String   @id @default(cuid())
  title         String
  description   String
  subject       String
  semester      String
  courseCode    String
  unit          String
  topic         String
  fileType      FileType
  fileSizeBytes Int
  pageCount     Int?
  storageKey    String?
  status        NoteStatus @default(PUBLISHED)
  rejectionReason String?
  reviewedAt    DateTime?
  reviewedById  String?
  ratingAverage Float    @default(0)
  ratingCount   Int      @default(0)
  downloadCount Int      @default(0)
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  /// Generated column (see note_search_vector migration); kept as Unsupported
  /// so Prisma preserves it without trying to manage its value.
  searchVector  Unsupported("tsvector")?

  owner     User            @relation(fields: [ownerId], references: [id])
  tags      NoteTag[]
  savedBy   SavedNote[]
  ratings   Rating[]
  downloads DownloadEvent[]
  moderationEvents ModerationEvent[]
  reports   Report[]

  @@index([subject])
  @@index([semester])
  @@index([courseCode])
  @@index([status])
  @@index([ownerId])
}

model ModerationEvent {
  id          String   @id @default(cuid())
  noteId      String
  moderatorId String
  action      String
  reason      String?
  createdAt   DateTime @default(now())

  note      Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  moderator User @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([moderatorId])
}

model Report {
  id          String   @id @default(cuid())
  noteId      String
  reporterId  String?
  reason      String
  details     String?
  status      ReportStatus @default(OPEN)
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  resolverId  String?

  note     Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  reporter User? @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)
  resolver User? @relation("ResolverReports", fields: [resolverId], references: [id], onDelete: SetNull)

  @@index([noteId])
  @@index([reporterId])
  @@index([status])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  notes NoteTag[]
}

model NoteTag {
  noteId String
  tagId  String

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

model SavedNote {
  userId    String
  noteId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([userId])
}

model Rating {
  userId    String
  noteId    String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([userId, noteId])
  @@index([noteId])
}

// Record of a raw file upload, written by /api/uploads before any Note
// exists. POST /api/notes validates its storageKey against this table so the
// browser cannot claim arbitrary keys or lie about size/type.
model UploadedFile {
  storageKey   String   @id
  userId       String
  provider     String   @default("LOCAL")
  mimeType     String
  sizeBytes    Int
  originalName String
  publicUrl    String?
  uploadedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DownloadEvent {
  id        String   @id @default(cuid())
  userId    String?
  noteId    String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  note Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([noteId, createdAt])
}
